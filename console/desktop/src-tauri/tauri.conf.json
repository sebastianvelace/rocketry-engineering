{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rocketry Workstation",
  "version": "0.1.0",
  "identifier": "local.rocketry.workstation",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Rocketry Workstation",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 640,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob:; connect-src 'self' ipc: http://127.0.0.1:* ws://127.0.0.1:* http://localhost:1420 ws://localhost:1420"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local agent and engineering workstation",
    "longDescription": "A unified local interface for Codex, Claude Code, ESP32 measurements, motor studies and flight simulation."
  }
}
